# Plant identification provider: plantnet (default/free) or plantid
PLANT_ID_PROVIDER=plantnet

# PlantNet — free 500 identifications/day — sign up at https://my.plantnet.org
PLANTNET_API_KEY=your_plantnet_api_key_here

# Plant.id — commercial alternative — only needed if PLANT_ID_PROVIDER=plantid
PLANT_ID_API_KEY=

# Trefle — free botanical database — sign up at https://trefle.io
TREFLE_API_KEY=your_trefle_token_here

# Change this to a long random string before deploying
SECRET_KEY=change-me-to-something-random
